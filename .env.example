# Environment Configuration Examples
# Copy this file to create your environment-specific .env files

# Client-side (VITE_ prefix)
# For local development with remote APIs:
VITE_API_BASE_URL=https://paynowdev.firstfintech.com/

# For local development with local APIs:
# VITE_API_BASE_URL=http://localhost:9001

# Server-side / build-time
VITE_ENV=development
MODE=development
PORT=3000
GENERATE_SOURCEMAP=true

# Future secrets (add to Jenkins credentials):
# VITE_API_KEY=your-api-key
# VITE_ANALYTICS_ID=your-analytics-id

# Optional:
# VITE_API_FILE_DOWNLOAD_URL=
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_RECAPTCHA_SITE_KEY=
# VITE_RSA_PUBLIC_KEY=